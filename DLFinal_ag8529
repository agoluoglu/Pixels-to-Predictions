t/plain":"special_tokens_map.json: 0.00B [00:00, ?B/s]","application/vnd.jupyter.widget-view+json":{"version_major":2,"version_minor":0,"model_id":"573fddc16d544c97845af95f5531b2e4"}},"metadata":{}},{"name":"stdout","text":"  full        :  mean=   272  median=   232  p95=   530  max=   685  | >512: 21 (7.0%)\n  hint_only   :  mean=   119  median=   102  p95=   257  max=   316  | >512: 0 (0.0%)\n  none        :  mean=    57  median=    52  p95=    82  max=   108  | >512: 0 (0.0%)\n\n============================================================\nSUBJECT DISTRIBUTION COMPARISON (train vs val vs test)\n============================================================\n  natural science     :  train= 72.8%  val= 74.1%  test= 73.2%\n  social science      :  train= 24.7%  val= 23.2%  test= 24.1%\n  language science    :  train=  2.5%  val=  2.7%  test=  2.7%\n","output_type":"stream"}],"execution_count":8},{"id":"bd9ec525-7f6f-4b94-8e0c-eae52efdbdfc","cell_type":"markdown","source":"### Data Examination Takeaways\n\n**Duplicates & leakage:** No duplicate IDs in any split. Question text is reused frequently (~63% of train \nrows share a question template with another row), but these seem to be distinct examples with different images, choices, and answers. This might just be by design in the dataset (many \"true or false?\" questions about different topics). The 204 train/val question overlaps are the same pattern, not data leakage/overlap between the two sets.\n\n**Choice distribution:** 49.9% of questions have 3 choices, 21.4% have 2 (binary true/false). \nThe weighted random baseline is 34.3%, so any accuracy result above that should indicate improvement over random selection.\n\n**Subject balance:** Natural science dominates at 73%, with biology and physics as the top topics. \nSocial science is 25%, language science is only 2.5%. Distribution is consistent across train/val/test \nsplits, so val accuracy should be a reliable proxy for test performance.\n\n**Context fields are mostly populated:** 14% of rows have empty lectures and 23% have empty hints. \nThis means \"full\" context mode actually does add information for most examples.\n\n**Prompt length is the key tension:** With full context, the mean is 272 tokens but p95 is 530 and \n7% of prompts exceed `max_seq_length` of 512. Those long prompts are being truncated, potentially \nlosing the question and answer choices at the end. \n\n**Decision**: Increase `max_seq_length` to 700.\n\n**No preprocessing transforms needed:** The data seems to be clean. No filtering, deduplication, or \nreformatting required. ","metadata":{}},{"id":"f0df1418","cell_type":"code","source":"# ── 2c. PyTorch Dataset ───────────────────────────────────────────────────────\nclass ScienceQADataset(Dataset):\n    def __init__(self, df, data_dir, img_size=512, is_train=True,\n                 context_mode=\"full\", prompt_format=\"context_first\",\n                 include_metadata=False, captions=None, answer_format=\"Answer:\"):\n        self.df             = df.reset_index(drop=True)\n        self.data_dir       = data_dir\n        self.img_size       = img_size\n        self.is_train       = is_train\n        self.context_mode   = context_mode\n        self.prompt_format  = prompt_format\n        self.include_metadata = include_metadata\n        self.captions       = captions\n        self.answer_format   = answer_format\n\n    def __len__(self):\n        return len(self.df)\n\n    def _load_image(self, rel_path):\n        # rel_path is e.g. \"images/train/train_00000.png\"\n        # strip the leading \"images/\" since IMAGE_DIR already points there\n        suffix = Path(rel_path).parts[1:]   # ('train', 'train_00000.png')\n        full_path = IMAGE_DIR.joinpath(*suffix)\n        img = Image.open(full_path).convert(\"RGB\")\n        #img = img.resize((self.img_size, self.img_size), Image.BICUBIC) # let processor handle resizing\n        return img\n\n    def __getitem__(self, idx):\n        row = self.df.iloc[idx]\n        img = self._load_image(row[\"image_path\"])\n\n        # Look up caption if available\n        caption = None\n        if self.captions is not None:\n            caption = self.captions.get(row[\"id\"], None)\n\n        if self.is_train:\n            return {\n                \"image\":  img,\n                \"text\":   build_prompt(row, include_answer=True,\n                                       context_mode=self.context_mode,\n                                       prompt_format=self.prompt_format,\n                                       include_metadata=self.include_metadata,\n                                       caption=caption,\n                                       answer_format=self.answer_format),\n                \"answer\": int(row[\"answer\"]),\n            }\n        else:\n            return {\n                \"image\":   img,\n                \"text\":    build_prompt(row, include_answer=False,\n                                        context_mode=self.context_mode,\n                                        prompt_format=self.prompt_format,\n                                        include_metadata=self.include_metadata,\n                                        caption=caption,\n                                       answer_format=self.answer_format),\n                \"choices\": row[\"choices\"],\n                \"answer\":  int(row[\"answer\"]) if \"answer\" in row else -1,\n            }\n\ntrain_ds = ScienceQADataset(train_df, DATA_DIR, img_size=IMG_SIZE, is_train=True,\n                             context_mode=CONFIG[\"context_mode\"],\n                             prompt_format=CONFIG[\"prompt_format\"],\n                             include_metadata=CONFIG[\"include_metadata\"],\n                             answer_format=CONFIG[\"answer_format\"])\nval_ds   = ScienceQADataset(val_df,   DATA_DIR, img_size=IMG_SIZE, is_train=False,\n                             context_mode=CONFIG[\"context_mode\"],\n                             prompt_format=CONFIG[\"prompt_format\"],\n                             include_metadata=CONFIG[\"include_metadata\"],\n                             answer_format=CONFIG[\"answer_format\"])\ntest_ds  = ScienceQADataset(test_df,  DATA_DIR, img_size=IMG_SIZE, is_train=False,\n                             context_mode=CONFIG[\"context_mode\"],\n                             prompt_format=CONFIG[\"prompt_format\"],\n                             include_metadata=CONFIG[\"include_metadata\"],\n                             answer_format=CONFIG[\"answer_format\"])\n\nprint(f\"Datasets created: train={len(train_ds)}, val={len(val_ds)}, test={len(test_ds)}\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-05-05T14:18:47.422482Z","iopub.execute_input":"2026-05-05T14:18:47.423703Z","iopub.status.idle":"2026-05-05T14:18:47.441791Z","shell.execute_reply.started":"2026-05-05T14:18:47.423667Z","shell.execute_reply":"2026-05-05T14:18:47.441026Z"}},"outputs":[{"name":"stdout","text":"Datasets created: train=3109, val=1048, test=1008\n","output_type":"stream"}],"execution_count":9},{"id":"764089e5","cell_type":"markdown","source":"## 3. Model Loading + LoRA","metadata":{}},{"id":"35ac655a-5748-4eeb-a34f-61055b884471","cell_type":"code","source":"# ── 3. Model Loading + QLoRA Setup ────────────────────────────────────────────\n# load SmolVLM in 4-bit NF4 (QLoRA) and apply LoRA adapters.\n# Trainable parameter count is printed and asserted against the 5M budget.\n\nfrom transformers import AutoProcessor, AutoModelForImageTextToText, BitsAndBytesConfig\nfrom peft import get_peft_model, LoraConfig, TaskType\n\ndef load_model_and_processor(cfg: dict):\n    \"\"\"\n    Load SmolVLM with QLoRA and apply LoRA adapters according to cfg.\n    Returns (model, processor).\n    \"\"\"\n    processor = AutoProcessor.from_pretrained(cfg[\"model_id\"])\n\n    # Disable tile splitting. without this the processor creates up to 17\n    # patches which OOMs on a 14.5GB GPU.\n    # With splitting off: 1 patch at imgsizeximgsize (~0.6MB per sample).\n    processor.image_processor.do_image_splitting = False # prevent OOM\n    \n    if processor.tokenizer.pad_token is None:\n        processor.tokenizer.pad_token = processor.tokenizer.eos_token\n\n    bnb_config = BitsAndBytesConfig(\n        load_in_4bit=cfg[\"load_in_4bit\"],\n        bnb_4bit_quant_type=\"nf4\",\n        bnb_4bit_compute_dtype=torch.float16,\n        bnb_4bit_use_double_quant=True,\n    )\n\n    model = AutoModelForImageTextToText.from_pretrained(\n        cfg[\"model_id\"],\n        quantization_config=bnb_config,\n        device_map=\"auto\",\n        low_cpu_mem_usage=True,\n    )\n\n    lora_cfg = LoraConfig(\n        r=cfg[\"lora_r\"],\n        lora_alpha=cfg[\"lora_alpha\"],\n        lora_dropout=cfg[\"lora_dropout\"],\n        target_modules=cfg[\"lora_target_modules\"],\n        task_type=TaskType.CAUSAL_LM,\n        bias=\"none\",\n        use_dora=cfg.get(\"use_dora\", False),\n    )\n    model = get_peft_model(model, lora_cfg)\n\n    # ── Parameter budget check ────────────────────────────────────────────────\n    trainable = sum(p.numel() for p in model.parameters() if p.requires_grad)\n    total     = sum(p.numel() for p in model.parameters())\n    print(f\"  Trainable params : {trainable:,}\")\n    print(f\"  Total params     : {total:,}\")\n    print(f\"  Trainable %      : {100 * trainable / total:.3f}%\")\n    assert trainable <= cfg[\"max_param_budget\"], (\n        f\"BUDGET EXCEEDED: {trainable:,} > {cfg['max_param_budget']:,}\"\n    )\n    print(f\" YAY! Within 5M budget!\")\n\n    # Trade compute for memory: recompute activations during backward instead of storing them. \n    # slows training but cuts activation memory so hopefully helps with OOM error\n    model.gradient_checkpointing_enable()\n    model.enable_input_require_grads()  # required when using gradient checkpointing with PEFT\n\n    return model, processor","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-05-05T14:18:47.442772Z","iopub.execute_input":"2026-05-05T14:18:47.443198Z","iopub.status.idle":"2026-05-05T14:19:13.240433Z","shell.execute_reply.started":"2026-05-05T14:18:47.443146Z","shell.execute_reply":"2026-05-05T14:19:13.239604Z"}},"outputs":[{"name":"stderr","text":"2026-05-05 14:18:49.953355: E external/local_xla/xla/stream_executor/cuda/cuda_fft.cc:467] Unable to register cuFFT factory: Attempting to register factory for plugin cuFFT when one has already been registered\nWARNING: All log messages before absl::InitializeLog() is called are written to STDERR\nE0000 00:00:1777990730.144503      57 cuda_dnn.cc:8579] Unable to register cuDNN factory: Attempting to register factory for plugin cuDNN when one has already been registered\nE0000 00:00:1777990730.209268      57 cuda_blas.cc:1407] Unable to register cuBLAS factory: Attempting to register factory for plugin cuBLAS when one has already been registered\nW0000 00:00:1777990730.700914      57 computation_placer.cc:177] computation placer already registered. Please check linkage and avoid linking the same target more than once.\nW0000 00:00:1777990730.700951      57 computation_placer.cc:177] computation placer already registered. Please check linkage and avoid linking the same target more than once.\nW0000 00:00:1777990730.700954      57 computation_placer.cc:177] computation placer already registered. Please check linkage and avoid linking the same target more than once.\nW0000 00:00:1777990730.700957      57 computation_placer.cc:177] computation placer already registered. Please check linkage and avoid linking the same target more than once.\n","output_type":"stream"}],"execution_count":10},{"id":"5df8421c-b86a-46ba-92f1-a6ec639f87ff","cell_type":"markdown","source":"## 4. Scoring Utilities","metadata":{}},{"id":"acb64f3b-3d1b-4eb5-9ae0-d0605866d99f","cell_type":"code","source":"# ── 4. Scoring Utilities ──────────────────────────────────────────────────────\n#\n# Two strategies for predicting the answer:\n#\n#  \"generate\" -> generate up to 5 tokens, parse the first letter (A/B/C...)\n#                     and convert to 0-indexed int.\n#\n#  \"loglikelihood\" -> for each choice, compute the avg log-likelihood that the\n#                     model assigns to that choice's letter given the prompt.\n#                     Pick the choice with the highest score. No parsing needed.\n#\n# Both functions take a single example dict (image, text, choices) and return a predicted answer index (int).\n\ndef predict_generate(model, processor, example, cfg):\n    \"\"\"Generate a letter and parse it to an answer index.\"\"\"\n    # Enforce processor settings — must be set on every call\n    processor.image_processor.do_image_splitting = False # prevent OOM\n    \n    inputs = processor(\n        text=[example[\"text\"]],\n        images=[example[\"image\"]],\n        return_tensors=\"pt\",\n        # max_length=cfg[\"max_seq_length\"],\n        # truncation=True,\n    )\n    inputs = {k: v.to(model.device) if torch.is_tensor(v) else v\n              for k, v in inputs.items()}\n\n    with torch.inference_mode():\n        out_ids = model.generate(\n            **inputs,\n            max_new_tokens=5,\n            do_sample=False,\n        )\n    decoded = processor.tokenizer.decode(\n        out_ids[0, inputs[\"input_ids\"].shape[1]:],   # only new tokens\n        skip_special_tokens=True,\n    ).strip()\n\n    # Parse first letter found\n    for ch in decoded.upper():\n        if ch in CHOICE_LETTERS:\n            return CHOICE_LETTERS.index(ch)\n    return 0   # fallback\n\n\ndef predict_loglikelihood(model, processor, example, cfg):\n    \"\"\"\n    Score each choice by the log-likelihood the model assigns to that\n    choice letter token, conditioned on the prompt. Return argmax.\n\n    Extract the logit at the last prompt position and score only\n    the candidate answer token. One forward pass per choice, but each\n    pass only looks at a single logit.\n\n    This is more robust than generation: no parsing, handles variable\n    numbers of choices naturally, and is faster (one forward pass per\n    choice vs. autoregressive decoding).\n    \"\"\"\n    # Enforce processor settings — must be set on every call\n    processor.image_processor.do_image_splitting = False\n\n    n_choices = len(example[\"choices\"])\n    scores = []\n\n    for i in range(n_choices):\n        candidate_letter = CHOICE_LETTERS[i]\n        scored_text = example[\"text\"] + f\" {candidate_letter}\"\n\n        inputs = processor(\n            text=[scored_text],\n            images=[example[\"image\"]],\n            return_tensors=\"pt\",\n        )\n        inputs = {k: v.to(model.device) if torch.is_tensor(v) else v\n                  for k, v in inputs.items()}\n\n        with torch.inference_mode():\n            outputs = model(**inputs)\n            logits = outputs.logits  # (1, seq_len, vocab_size)\n\n            # The answer token is the last real token in the sequence.\n            # The logit that *predicts* it is at position -2\n            # (logits[t] predicts token[t+1] in causal LM).\n            answer_token_id = inputs[\"input_ids\"][0, -1].item()\n            logit_at_answer = logits[0, -2, :]  # logit predicting the last token\n\n            log_probs = torch.nn.functional.log_softmax(logit_at_answer, dim=-1)\n            score = log_probs[answer_token_id].item()\n            scores.append(score)\n\n    return int(np.argmax(scores))\n\n\ndef predict(model, processor, example, cfg):\n    \"\"\"Dispatch to the correct scoring strategy from cfg.\"\"\"\n    if cfg[\"scoring_strategy\"] == \"generate\":\n        return predict_generate(model, processor, example, cfg)\n    elif cfg[\"scoring_strategy\"] == \"loglikelihood\":\n        return predict_loglikelihood(model, processor, example, cfg)\n    else:\n        raise ValueError(f\"Unknown scoring_strategy: {cfg['scoring_strategy']}\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-05-05T14:19:13.241459Z","iopub.execute_input":"2026-05-05T14:19:13.242209Z","iopub.status.idle":"2026-05-05T14:19:13.255521Z","shell.execute_reply.started":"2026-05-05T14:19:13.242159Z","shell.execute_reply":"2026-05-05T14:19:13.254755Z"}},"outputs":[],"execution_count":11},{"id":"497e43c4-1bb1-4102-b374-c42d0c644aee","cell_type":"markdown","source":"## 5. Training & Evaluation Utilities\n\nThis section defines three core functions used by the ablation and full training loops:\n\n- **`collate_fn`**: When DataLoader grabs multiple samples (batch_size=4), each sample may have \n  a different sequence length. This function takes these mismatched samples, runs them through the \n  processor (which handles both images and text together), pads them to equal length, and assembles them \n  into proper batched tensors the model can consume.\n\n  **Key design choice:** labels are masked with `-100` \n  on all prompt tokens so the loss is computed only on the answer tokens. The model still attends to the \n  full prompt (context, question, choices, image). This only changes what the optimizer trains on, \n  focusing the gradient signal entirely on predicting the correct answer letter.\n\n- **`evaluate`**: Runs inference on a subset of the validation set and returns accuracy. Used both during \n  ablation (on `eval_subset_size` samples every N steps) and after full training.\n\n- **`run_training`**: The main training loop. Supports two modes: short ablation runs (fixed number of steps) \n  and full training (fixed number of epochs). Handles gradient accumulation, cosine LR scheduling, \n  periodic evaluation, and loss/accuracy logging.","metadata":{}},{"id":"39913f7c-1620-4543-829a-e821c7d6672c","cell_type":"code","source":"# ── 5. Training & Evaluation Utilities ───────────────────────────────────────\nimport time\nfrom torch.utils.data import DataLoader, Subset\nfrom transformers import get_cosine_schedule_with_warmup\n\ndef collate_fn(batch, processor, cfg):\n    \"\"\"\n    Process each sample individually. Processor settings are enforced\n    inside this function on every call so they cannot be reset externally.\n    \n    Labels are masked with -100 on all prompt tokens so the loss is computed \n    only on the answer token(s). Uses the already-tokenized input_ids to find\n    answer boundaries, avoiding tokenizer context-dependency issues.\n    \"\"\"\n    processor.image_processor.do_image_splitting = False\n\n    batch_texts = [item[\"text\"] for item in batch]\n\n    all_inputs = []\n    for item in batch:\n        inp = processor(\n            text=[item[\"text\"]],\n            images=[item[\"image\"]],\n            return_tensors=\"pt\",\n            padding=False,\n        )\n        all_inputs.append(inp)\n\n    pixel_values = torch.cat([x[\"pixel_values\"] for x in all_inputs], dim=0)\n    pixel_attention_mask = torch.cat(\n        [x[\"pixel_attention_mask\"] for x in all_inputs], dim=0\n    )\n\n    max_len = min(\n        max(x[\"input_ids\"].shape[1] for x in all_inputs),\n        cfg[\"max_seq_length\"]\n    )\n    pad_id = processor.tokenizer.pad_token_id\n\n    input_ids_padded      = []\n    attention_mask_padded  = []\n\n    for inp in all_inputs:\n        ids  = inp[\"input_ids\"][0][:max_len]\n        mask = inp[\"attention_mask\"][0][:max_len]\n        pad_len = max_len - ids.shape[0]\n        ids  = torch.cat([ids,  torch.full((pad_len,), pad_id,  dtype=ids.dtype)])\n        mask = torch.cat([mask, torch.zeros(pad_len,            dtype=mask.dtype)])\n        input_ids_padded.append(ids)\n        attention_mask_padded.append(mask)\n\n    input_ids      = torch.stack(input_ids_padded)\n    attention_mask = torch.stack(attention_mask_padded)\n    \n    # Build labels: mask everything, then unmask only the answer tokens\n    labels = torch.full_like(input_ids, -100)\n    \n    answer_format = cfg.get(\"answer_format\", \"Answer:\")\n    \n    for i in range(input_ids.shape[0]):\n        # Find the last non-pad token position\n        non_pad_mask = (input_ids[i] != pad_id)\n        if not non_pad_mask.any():\n            continue\n        last_real_pos = non_pad_mask.nonzero(as_tuple=True)[0][-1].item()\n        \n        # Extract the answer portion from the full text and tokenize it\n        # to know exactly how many tokens to unmask\n        full_text = batch_texts[i]\n        if answer_format in full_text:\n            answer_part = full_text.split(answer_format)[-1]  # e.g., \" A\"\n        else:\n            answer_part = full_text[-3:]  # fallback\n        \n        answer_token_ids = processor.tokenizer.encode(answer_part, add_special_tokens=False)\n        n_answer_tokens = len(answer_token_ids)\n        \n        # Unmask only the answer tokens at the end\n        answer_start = max(0, last_real_pos - n_answer_tokens + 1)\n        labels[i, answer_start:last_real_pos + 1] = input_ids[i, answer_start:last_real_pos + 1]\n\n    return {\n        \"pixel_values\":         pixel_values,\n        \"pixel_attention_mask\": pixel_attention_mask,\n        \"input_ids\":            input_ids,\n        \"attention_mask\":       attention_mask,\n        \"labels\":               labels,\n    }\n\ndef evaluate(model, processor, val_df, cfg, n_samples=None):\n    \"\"\"\n    Run evaluation on a subset of val_df.\n    Returns accuracy (float) and list of per-step losses (empty list here —\n    losses are tracked during training, not eval).\n    \"\"\"\n    # Enforce processor settings — must be set on every call\n    processor.image_processor.do_image_splitting = False # prevent OOM\n    \n    model.eval()\n    n = n_samples or len(val_df)\n    subset = val_df.sample(n=min(n, len(val_df)), random_state=SEED)\n\n    correct = 0\n    for _, row in subset.iterrows():\n        img_suffix = Path(row[\"image_path\"]).parts[1:]\n        img = Image.open(IMAGE_DIR.joinpath(*img_suffix)).convert(\"RGB\")\n        #img = img.resize((cfg[\"img_size\"], cfg[\"img_size\"]), Image.BICUBIC) #let processor handle\n        caption = None\n        if cfg.get(\"_captions_dict\"):\n            caption = cfg[\"_captions_dict\"].get(row[\"id\"], None)\n        example = {\n            \"image\":   img,\n            \"text\":    build_prompt(row, include_answer=False,\n                                    context_mode=cfg[\"context_mode\"],\n                                    prompt_format=cfg.get(\"prompt_format\", \"context_first\"),\n                                    include_metadata=cfg.get(\"include_metadata\", False),\n                                    caption=caption,\n                                    answer_format=cfg.get(\"answer_format\", \"Answer:\")),\n            \"choices\": row[\"choices\"],\n        }\n        pred = predict(model, processor, example, cfg)\n        if pred == int(row[\"answer\"]):\n            correct += 1\n\n    accuracy = correct / len(subset)\n    model.train()\n    return accuracy\n\n\ndef run_training(model, processor, train_df, val_df, cfg,\n                 max_steps=None, full_train=False):\n    \"\"\"\n    Train model for either `cfg['ablation_steps']` steps (ablation mode)\n    or `cfg['full_train_epochs']` epochs (full training mode).\n\n    Returns a result dict with:\n        train_losses  : list of (step, loss) tuples\n        val_accuracies: list of (step, accuracy) tuples\n        trainable_params: int\n        total_time_min: float\n    \"\"\"\n    max_steps = max_steps or (\n        None if full_train else cfg[\"ablation_steps\"]\n    )\n\n    dataset = ScienceQADataset(\n        train_df, DATA_DIR,\n        img_size=cfg[\"img_size\"],\n        is_train=True,\n        context_mode=cfg[\"context_mode\"],\n        prompt_format=cfg.get(\"prompt_format\", \"context_first\"),\n        include_metadata=cfg.get(\"include_metadata\", False),\n        captions=cfg.get(\"_captions_dict\", None),\n        answer_format=cfg.get(\"answer_format\", \"Answer:\"),\n    )\n    loader = DataLoader(\n        dataset,\n        batch_size=cfg[\"batch_size\"],\n        shuffle=True,\n        collate_fn=lambda b: collate_fn(b, processor, cfg),\n        num_workers=0,   # avoids multiprocessing issues with the processor object\n        pin_memory=True,\n    )\n\n    optimizer = torch.optim.AdamW(\n        filter(lambda p: p.requires_grad, model.parameters()),\n        lr=cfg[\"learning_rate\"],\n    )\n\n    total_steps = max_steps or (\n        len(loader) * cfg[\"full_train_epochs\"]\n    )\n    scheduler = get_cosine_schedule_with_warmup(\n        optimizer,\n        num_warmup_steps=max(1, total_steps // 10),\n        num_training_steps=total_steps,\n    )\n\n    trainable_params = sum(\n        p.numel() for p in model.parameters() if p.requires_grad\n    )\n\n    train_losses   = []\n    val_accuracies = []\n    step = 0\n    t0   = time.time()\n\n    model.train()\n    optimizer.zero_grad()\n\n    epochs = cfg[\"full_train_epochs\"] if full_train else 999  # capped by max_steps\n    for epoch in range(epochs):\n        for batch in loader:\n            batch = {k: v.to(model.device) if torch.is_tensor(v) else v\n                     for k, v in batch.items()}\n\n            outputs = model(**batch)\n            loss    = outputs.loss / cfg[\"grad_accumulation\"]\n            loss.backward()\n\n            if (step + 1) % cfg[\"grad_accumulation\"] == 0:\n                torch.nn.utils.clip_grad_norm_(model.parameters(), 1.0)\n                optimizer.step()\n                scheduler.step()\n                optimizer.zero_grad()\n\n            train_losses.append((step, outputs.loss.item()))\n\n            # ── Periodic eval ─────────────────────────────────────────────\n            if (step + 1) % cfg[\"eval_every_n_steps\"] == 0:\n                acc = evaluate(model, processor, val_df, cfg,\n                               n_samples=cfg[\"eval_subset_size\"])\n                val_accuracies.append((step + 1, acc))\n                print(f\"  step {step+1:>4} | loss {outputs.loss.item():.4f} \"\n                      f\"| val_acc {acc:.3f}\")\n\n            step += 1\n            if max_steps and step >= max_steps:\n                break\n        if max_steps and step >= max_steps:\n            break\n\n        # ── End-of-epoch checkpoint (full training only) ──────────────────\n        if full_train:\n            epoch_acc = evaluate(model, processor, val_df, cfg,\n                                 n_samples=cfg[\"eval_subset_size\"])\n            val_accuracies.append((step, epoch_acc))\n            print(f\"\\n  ── Epoch {epoch+1} complete | step {step} | val_acc {epoch_acc:.3f} ──\")\n\n            ckpt_path = OUTPUT_DIR / f\"checkpoint_epoch{epoch+1}\"\n            model.save_pretrained(ckpt_path)\n            processor.save_pretrained(ckpt_path)\n            # Save training state for resumption\n            torch.save({\n                \"optimizer\": optimizer.state_dict(),\n                \"scheduler\": scheduler.state_dict(),\n                \"step\": step,\n                \"epoch\": epoch + 1,\n                \"train_losses\": train_losses,\n                \"val_accuracies\": val_accuracies,\n            }, ckpt_path / \"training_state.pt\")\n            print(f\"  Checkpoint saved to {ckpt_path}\")\n\n    total_time_min = (time.time() - t0) / 60\n    return {\n        \"train_losses\":    train_losses,\n        \"val_accuracies\":  val_accuracies,\n        \"trainable_params\": trainable_params,\n        \"total_time_min\":  total_time_min,\n    }","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-05-05T14:43:53.728339Z","iopub.execute_input":"2026-05-05T14:43:53.729103Z","iopub.status.idle":"2026-05-05T14:43:53.757535Z","shell.execute_reply.started":"2026-05-05T14:43:53.729065Z","shell.execute_reply":"2026-05-05T14:43:53.756706Z"}},"outputs":[],"execution_count":26},{"id":"85f1bad7-e228-407b-8d0d-91ff8e06efb9","cell_type":"markdown","source":"## 6. Ablation Testing","metadata":{}},{"id":"42502aae-7142-4991-8aa7-429ce56a90ae","cell_type":"code","source":"# let ablation results be persistent across sessions\nimport os, json, gc\n\nRESULTS_FILE = OUTPUT_DIR / \"ablation_results.json\"\nRESULTS_FILE_INPUT = Path(\"/kaggle/input/datasets/ashleygoluoglu/ablation\") / \"ablation_results.json\"\n\n# Load existing results: check output dir first, then input dir\nif RESULTS_FILE.exists():\n    with open(RESULTS_FILE) as f:\n        ABLATION_RESULTS = json.load(f)\n    print(f\"Loaded {len(ABLATION_RESULTS)} existing results from {RESULTS_FILE}\")\nelif RESULTS_FILE_INPUT.exists():\n    with open(RESULTS_FILE_INPUT) as f:\n        ABLATION_RESULTS = json.load(f)\n    print(f\"Loaded {len(ABLATION_RESULTS)} existing results from {RESULTS_FILE_INPUT}\")\nelse:\n    ABLATION_RESULTS = {}\n    print(\"Starting fresh ablation results dict\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-05-05T14:19:13.296050Z","iopub.execute_input":"2026-05-05T14:19:13.296355Z","iopub.status.idle":"2026-05-05T14:19:13.309090Z","shell.execute_reply.started":"2026-05-05T14:19:13.296324Z","shell.execute_reply":"2026-05-05T14:19:13.308231Z"}},"outputs":[{"name":"stdout","text":"Loaded 15 existing results from /kaggle/working/ablation_results.json\n","output_type":"stream"}],"execution_count":13},{"id":"797133e3-011a-455c-aba2-39b76143b040","cell_type":"code","source":"# Save after every completed run so nothing is lost on crash\ndef save_results(results, path):\n    # loss/acc tuples are already JSON-serializable\n    # but config may contain Path objects, so stringify those\n    serializable = {}\n    for k, v in results.items():\n        serializable[k] = {\n            \"train_losses\":      v[\"train_losses\"],\n            \"val_accuracies\":    v[\"val_accuracies\"],\n            \"trainable_params\":  v[\"trainable_params\"],\n            \"total_time_min\":    v[\"total_time_min\"],\n            \"final_val_accuracy\": v[\"final_val_accuracy\"],\n            \"config\": {ck: str(cv) if isinstance(cv, Path) else cv for ck, cv in v[\"config\"].items()}, #\"config\": {ck: str(cv) for ck, cv in v[\"config\"].items()},\n        }\n    with open(path, \"w\") as f:\n        json.dump(serializable, f, indent=2)","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-05-05T14:38:07.024575Z","iopub.execute_input":"2026-05-05T14:38:07.025541Z","iopub.status.idle":"2026-05-05T14:38:07.032670Z","shell.execute_reply.started":"2026-05-05T14:38:07.025501Z","shell.execute_reply":"2026-05-05T14:38:07.031808Z"}},"outputs":[],"execution_count":20},{"id":"7a65e3a3-8ece-400f-8d7c-adab19ff5674","cell_type":"code","source":"# Check param counts at different ranks so we can see which ranks we can do ablations with\nconfigs_to_test = [\n    (\"attn_only r16\", 16, [\"q_proj\", \"v_proj\", \"k_proj\", \"o_proj\"]),\n    (\"all7 r8\",        8, [\"q_proj\", \"v_proj\", \"k_proj\", \"o_proj\", \"gate_proj\", \"up_proj\", \"down_proj\"]),\n    (\"all7 r6\",        6, [\"q_proj\", \"v_proj\", \"k_proj\", \"o_proj\", \"gate_proj\", \"up_proj\", \"down_proj\"]),\n    (\"all7 r4\",        4, [\"q_proj\", \"v_proj\", \"k_proj\", \"o_proj\", \"gate_proj\", \"up_proj\", \"down_proj\"]),\n]\n\nfrom peft import get_peft_model, LoraConfig, TaskType\nfrom transformers import AutoModelForImageTextToText, BitsAndBytesConfig\nimport torch, gc\n\nbnb_config = BitsAndBytesConfig(\n    load_in_4bit=True,\n    bnb_4bit_quant_type=\"nf4\",\n    bnb_4bit_compute_dtype=torch.float16,\n    bnb_4bit_use_double_quant=True,\n)\n\nfor name, r, modules in configs_to_test:\n    model = AutoModelForImageTextToText.from_pretrained(\n        \"HuggingFaceTB/SmolVLM-500M-Instruct\",\n        quantization_config=bnb_config,\n        device_map=\"auto\",\n        low_cpu_mem_usage=True,\n    )\n    lora_cfg = LoraConfig(\n        r=r, lora_alpha=2*r, lora_dropout=0.05,\n        target_modules=modules, task_type=TaskType.CAUSAL_LM, bias=\"none\",\n    )\n    peft_model = get_peft_model(model, lora_cfg)\n    trainable = sum(p.numel() for p in peft_model.parameters() if p.requires_grad)\n    print(f\"  {name:<20s}: {trainable:>10,} params  {'OK' if trainable <= 5_000_000 else 'OVER BUDGET'}\")\n    del peft_model, model\n    gc.collect()\n    torch.cuda.empty_cache()","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-05-05T14:19:13.325652Z","iopub.execute_input":"2026-05-05T14:19:13.326044Z","iopub.status.idle":"2026-05-05T14:19:31.680559Z","shell.execute_reply.started":"2026-05-05T14:19:13.326011Z","shell.execute_reply":"2026-05-05T14:19:31.679739Z"}},"outputs":[{"output_type":"display_data","data":{"text/plain":"config.json: 0.00B [00:00, ?B/s]","application/vnd.jupyter.widget-view+json":{"version_major":2,"version_minor":0,"model_id":"55bf97d11fe749a1b46815e1ef88df08"}},"metadata":{}},{"output_type":"display_data","data":{"text/plain":"model.safetensors:   0%|          | 0.00/1.02G [00:00<?, ?B/s]","application/vnd.jupyter.widget-view+json":{"version_major":2,"version_minor":0,"model_id":"c30133a3fd6f4ce38e8f961819e3a03c"}},"metadata":{}},{"output_type":"display_data","data":{"text/plain":"generation_config.json:   0%|          | 0.00/136 [00:00<?, ?B/s]","application/vnd.jupyter.widget-view+json":{"version_major":2,"version_minor":0,"model_id":"988b92bea08b439d99b0813297bc8d19"}},"metadata":{}},{"name":"stdout","text":"  attn_only r16       :  4,161,536 params  OK\n  all7 r8             :  4,784,128 params  OK\n  all7 r6             :  3,588,096 params  OK\n  all7 r4             :  2,392,064 params  OK\n","output_type":"stream"}],"execution_count":15},{"id":"e29ce938-ca2d-4ff6-be02-90bb28a5f279","cell_type":"code","source":"# param check for Dora \nfor name, r, modules in [\n    (\"all7 r8 DoRA\",  8, [\"q_proj\", \"v_proj\", \"k_proj\", \"o_proj\", \"gate_proj\", \"up_proj\", \"down_proj\"]),\n    (\"all7 r6 DoRA\",  6, [\"q_proj\", \"v_proj\", \"k_proj\", \"o_proj\", \"gate_proj\", \"up_proj\", \"down_proj\"]),\n    (\"attn r16 DoRA\", 16, [\"q_proj\", \"v_proj\", \"k_proj\", \"o_proj\"]),\n]:\n    model = AutoModelForImageTextToText.from_pretrained(\n        \"HuggingFaceTB/SmolVLM-500M-Instruct\",\n        quantization_config=bnb_config,\n        device_map=\"auto\",\n        low_cpu_mem_usage=True,\n    )\n    lora_cfg = LoraConfig(\n        r=r, lora_alpha=2*r, lora_dropout=0.05,\n        target_modules=modules, task_type=TaskType.CAUSAL_LM, bias=\"none\",\n        use_dora=True,\n    )\n    peft_model = get_peft_model(model, lora_cfg)\n    trainable = sum(p.numel() for p in peft_model.parameters() if p.requires_grad)\n    print(f\"  {name:<20s}: {trainable:>10,} params  {'OK' if trainable <= 5_000_000 else 'OVER BUDGET'}\")\n    del peft_model, model\n    gc.collect()\n    torch.cuda.empty_cache()","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-05-05T14:19:31.681576Z","iopub.execute_input":"2026-05-05T14:19:31.682412Z","iopub.status.idle":"2026-05-05T14:19:40.884415Z","shell.execute_reply.started":"2026-05-05T14:19:31.682365Z","shell.execute_reply":"2026-05-05T14:19:40.883618Z"}},"outputs":[{"name":"stdout","text":"  all7 r8 DoRA        :  5,088,256 params  OVER BUDGET\n  all7 r6 DoRA        :  3,892,224 params  OK\n  attn r16 DoRA       :  4,271,104 params  OK\n","output_type":"stream"}],"execution_count":16},{"id":"a706260f-6566-40c6-95bf-b0c9284f803f","cell_type":"code","source":"# ── 6. Ablation Experiments ───────────────────────────────────────────────────\n#\n# test one axis at a time, keeping everything else at the default CONFIG.\n# Each run is CONFIG[\"ablation_steps\"] steps\n# short enough to compare quickly, long enough that relative rankings are hopefully meaningful\n#\n# After each axis, the winner is locked in for the next axis.\n\n# NOTE: update the axis2+ overrides in ablation plan after seeing axis1 results and so on\n# Don't run all axes at once when trying to reproduce/make changes \n# run one at a time and update\n\n# Updated after tips given:\n# Starting control config:\n#   - all7 modules (q/v/k/o + gate/up/down)\n#   - rank 8\n#   - DoRA off (to be tested)\n#   - include_metadata: True\n#   - answer_format: \"The correct answer is:\"\n#   - use_captions: False \n#   - generate scoring\n#   - learning_rate: 2e-4\n\nimport copy\n\n# Each entry: (run_name, dict of CONFIG overrides)\nABLATION_PLAN = [\n\n    # ── Axis 1: Scoring strategy ──────────────────────────────────────────\n    (\"a1_generate\",       {\"scoring_strategy\": \"generate\",\n                           \"lora_r\": 8, \"use_dora\": False, \"include_metadata\": True,\n                           \"answer_format\": \"The correct answer is:\",\n                           \"lora_target_modules\": [\"q_proj\", \"v_proj\", \"k_proj\", \"o_proj\",\n                                                   \"gate_proj\", \"up_proj\", \"down_proj\"]}),\n    (\"a1_loglikelihood\",  {\"scoring_strategy\": \"loglikelihood\",\n                           \"lora_r\": 8, \"use_dora\": False, \"include_metadata\": True,\n                           \"answer_format\": \"The correct answer is:\",\n                           \"lora_target_modules\": [\"q_proj\", \"v_proj\", \"k_proj\", \"o_proj\",\n                                                   \"gate_proj\", \"up_proj\", \"down_proj\"]}),\n\n    # ── Axis 2: DoRA (locked: generate) ──────────────────────────────────\n    # Note: DoRA + all7 r8 exceeds 5M budget, so DoRA tested at r6\n    (\"a2_no_dora_r8\",     {\"scoring_strategy\": \"generate\",\n                           \"lora_r\": 8, \"use_dora\": False, \"include_metadata\": True,\n                           \"answer_format\": \"The correct answer is:\",\n                           \"lora_target_modules\": [\"q_proj\", \"v_proj\", \"k_proj\", \"o_proj\",\n                                                   \"gate_proj\", \"up_proj\", \"down_proj\"]}),\n    (\"a2_dora_r6\",        {\"scoring_strategy\": \"generate\",\n                           \"lora_r\": 6, \"use_dora\": True, \"include_metadata\": True,\n                           \"answer_format\": \"The correct answer is:\",\n                           \"lora_target_modules\": [\"q_proj\", \"v_proj\", \"k_proj\", \"o_proj\",\n                                                   \"gate_proj\", \"up_proj\", \"down_proj\"]}),\n\n    # ── Axis 3: Target modules (reduce modules, increase rank in both dora and no dora) ───────────\n    # update scoring_strategy, use_dora\n    (\"a3_attn_only\",      {\"scoring_strategy\": \"generate\", \"use_dora\": False,\n                           \"lora_r\": 16, \"include_metadata\": True,\n                           \"answer_format\": \"The correct answer is:\",\n                           \"lora_target_modules\": [\"q_proj\", \"v_proj\", \"k_proj\", \"o_proj\"]}),\n    (\"a3_attn_only_dora\",      {\"scoring_strategy\": \"generate\", \"use_dora\": True,\n                           \"lora_r\": 16, \"include_metadata\": True,\n                           \"answer_format\": \"The correct answer is:\",\n                           \"lora_target_modules\": [\"q_proj\", \"v_proj\", \"k_proj\", \"o_proj\"]}),\n\n    # ── Axis 4: Prompt + architecture combos ─────────────────────────────\n    # Test prompt engineering variations across two best architectures so far\n    # Architecture A: attn-only r16, no DoRA (current best at 68%)\n    # Architecture B: all7 r8, no DoRA (61%)\n    \n    # -- Prompt variations on best architecture (attn r16) --\n    (\"a4_attn16_bare\",          {\"scoring_strategy\": \"generate\", \"use_dora\": False, \"lora_r\": 16,\n                                 \"include_metadata\": False, \"answer_format\": \"Answer:\",\n                                 \"lora_target_modules\": [\"q_proj\", \"v_proj\", \"k_proj\", \"o_proj\"]}),\n    (\"a4_attn16_meta_only\",     {\"scoring_strategy\": \"generate\", \"use_dora\": False, \"lora_r\": 16,\n                                 \"include_metadata\": True, \"answer_format\": \"Answer:\",\n                                 \"lora_target_modules\": [\"q_proj\", \"v_proj\", \"k_proj\", \"o_proj\"]}),\n    (\"a4_attn16_fmt_only\",      {\"scoring_strategy\": \"generate\", \"use_dora\": False, \"lora_r\": 16,\n                                 \"include_metadata\": False, \"answer_format\": \"The correct answer is:\",\n                                 \"lora_target_modules\": [\"q_proj\", \"v_proj\", \"k_proj\", \"o_proj\"]}),\n    # a3_attn_only already covers attn16 + meta + fmt (68%), so skip that combo\n    \n    # -- Same prompt variations on all7 r8 --\n    (\"a4_all7r8_bare\",          {\"scoring_strategy\": \"generate\", \"use_dora\": False, \"lora_r\": 8,\n                                 \"include_metadata\": False, \"answer_format\": \"Answer:\",\n                                 \"lora_target_modules\": [\"q_proj\", \"v_proj\", \"k_proj\", \"o_proj\",\n                                                         \"gate_proj\", \"up_proj\", \"down_proj\"]}),\n    (\"a4_all7r8_meta_only\",     {\"scoring_strategy\": \"generate\", \"use_dora\": False, \"lora_r\": 8,\n                                 \"include_metadata\": True, \"answer_format\": \"Answer:\",\n                                 \"lora_target_modules\": [\"q_proj\", \"v_proj\", \"k_proj\", \"o_proj\",\n                                                         \"gate_proj\", \"up_proj\", \"down_proj\"]}),\n    (\"a4_all7r8_fmt_only\",      {\"scoring_strategy\": \"generate\", \"use_dora\": False, \"lora_r\": 8,\n                                 \"include_metadata\": False, \"answer_format\": \"The correct answer is:\",\n                                 \"lora_target_modules\": [\"q_proj\", \"v_proj\", \"k_proj\", \"o_proj\",\n                                                         \"gate_proj\", \"up_proj\", \"down_proj\"]}),\n    # a1_generate already covers all7r8 + meta + fmt (61%), so skip that combo\n\n    # -- DoRA versions of the two best combos --\n    # a3_attn_only_dora already covers attn16 + DoRA + meta + fmt (65%)\n    (\"a4_all7r6_dora_meta_fmt\", {\"scoring_strategy\": \"generate\", \"use_dora\": True, \"lora_r\": 6,\n                                 \"include_metadata\": True, \"answer_format\": \"The correct answer is:\",\n                                 \"lora_target_modules\": [\"q_proj\", \"v_proj\", \"k_proj\", \"o_proj\",\n                                                         \"gate_proj\", \"up_proj\", \"down_proj\"]}),\n    \n    # -- all hints: all7 r4 + DoRA + meta + fmt --\n    (\"a4_allhints_config\",       {\"scoring_strategy\": \"generate\", \"use_dora\": True, \"lora_r\": 4,\n                                 \"include_metadata\": True, \"answer_format\": \"The correct answer is:\",\n                                 \"lora_target_modules\": [\"q_proj\", \"v_proj\", \"k_proj\", \"o_proj\",\n                                                         \"gate_proj\", \"up_proj\", \"down_proj\"]}),\n]\n\n# ── Run all ablations ─────────────────────────────────────────────────────────\n\nfor run_name, overrides in ABLATION_PLAN:\n    # don't run ones that hve already been done\n    if run_name in ABLATION_RESULTS:\n        print(f\"  Skipping {run_name} (already in results)\")\n        continue\n        \n    print(f\"\\n{'='*60}\")\n    print(f\"  RUN: {run_name}\")\n    print(f\"  Overrides: {overrides}\")\n    print(f\"{'='*60}\")\n\n    # Build this run's config\n    run_cfg = copy.deepcopy(CONFIG)\n    run_cfg.update(overrides)\n\n    # clear cache, should help with memory\n    gc.collect()\n    torch.cuda.empty_cache()\n    torch.cuda.reset_peak_memory_stats()\n\n    # Load fresh model + processor for each run\n    model, processor = load_model_and_processor(run_cfg)\n\n    # Train\n    result = run_training(model, processor, train_df, val_df, run_cfg)\n    result[\"config\"] = run_cfg\n\n    # Final val accuracy on full eval subset\n    final_acc = evaluate(model, processor, val_df, run_cfg,\n                         n_samples=run_cfg[\"eval_subset_size\"])\n    result[\"final_val_accuracy\"] = final_acc\n\n    ABLATION_RESULTS[run_name] = result\n    save_results(ABLATION_RESULTS, RESULTS_FILE)\n    print(f\"  Results saved to {RESULTS_FILE}\")\n\n    print(f\"\\n{run_name} done | \"\n          f\"final_val_acc={final_acc:.3f} | \"\n          f\"time={result['total_time_min']:.1f} min\")\n\n    # Free memory before next run\n    del model\n    torch.cuda.empty_cache()","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-05-05T14:19:40.885628Z","iopub.execute_input":"2026-05-05T14:19:40.885972Z","iopub.status.idle":"2026-05-05T14:19:40.903150Z","shell.execute_reply.started":"2026-05-05T14:19:40.885941Z","shell.execute_reply":"2026-05-05T14:19:40.902478Z"}},"outputs":[{"name":"stdout","text":"  Skipping a1_generate (already in results)\n  Skipping a1_loglikelihood (already in results)\n  Skipping a2_no_dora_r8 (already in results)\n  Skipping a2_dora_r6 (already in results)\n  Skipping a3_attn_only (already in results)\n  Skipping a3_attn_only_dora (already in results)\n  Skipping a4_attn16_bare (already in results)\n  Skipping a4_attn16_meta_only (already in results)\n  Skipping a4_attn16_fmt_only (already in results)\n  Skipping a4_all7r8_bare (already in results)\n  Skipping a4_all7r8_meta_only (already in results)\n  Skipping a4_all7r8_fmt_only (already in results)\n  Skipping a4_all7r6_dora_meta_fmt (already in results)\n  Skipping a4_allhints_config (already in results)\n","output_type":"stream"}],"execution_count":17},{"id":"d1e997d9-832e-499f-b79d-b579dba48389","cell_type":"markdown","source":"## ORIGINAL Ablation Axes & Notes","metadata":{}},{"id":"ea276305-995f-45e3-981f-37e874a317db","cell_type":"markdown","source":"### Axis 1 Results: Scoring Strategy\n\n| Run | Step 100 Acc | Step 200 Acc | Final Val Acc | Time |\n|-----|-------------|-------------|---------------|------|\n| generate | 0.430 | 0.460 | 0.460 | 9.4 min |\n| loglikelihood | 0.425 | 0.465 | 0.465 | 10.6 min |\n\n**Decision: generate.** Accuracies are within noise (about 0.5%, or 1 example on 200 samples). \nNeither strategy shows a clear advantage at 200 steps. Choose to select generate because:\n1. Faster evaluation (one generate call vs N forward passes per choice)\n2. Faster submission generation on the test set\n3. Training loss gives clearer convergence signal with label masking\n\n**Note:** With only two eval points and a near-tie, this is a low-confidence decision. \nLoglikelihood *could* pull ahead with longer training. If final test accuracy disappoints, \nthis is worth revisiting.","metadata":{}},{"id":"37ca85a5-d93f-4a30-bcfe-b47ce03f05e0","cell_type":"markdown","source":"### Axis 2 Results: LoRA Rank\n\n| Run | Trainable Params | Step 100 Acc | Step 200 Acc | Final Val Acc | Time |\n|-----|-----------------|-------------|-------------|---------------|------|\n| rank 4 | 557,056 | 0.435 | 0.465 | 0.465 | 9.1 min |\n| rank 8 | 1,114,112 | 0.440 | 0.475 | 0.475 | 9.0 min |\n| rank 16 | 2,228,224 | 0.425 | 0.470 | 0.470 | 8.9 min |\n\n**Decision: rank 8.** It edges out the others at 47.5%, though again the margins are tight \n(1-2 examples on 200 samples). Rank 16 doesn't improve over rank 8 despite doubling the \nparameters. This suggests the model's bottleneck at this stage isn't adapter capacity. \nRank 4 is surprisingly competitive, confirming that the task doesn't need many trainable \nparameters.\n\nAll three configurations are well within the 5M parameter budget, so budget isn't a factor here. \nRank 8 offers a good balance: enough capacity without overfitting risk on a short run.","metadata":{}},{"id":"2a1367b7-ef89-45b8-89f4-f7b88e9fd356","cell_type":"markdown","source":"### Axis 3 Results: LoRA Target Modules\n\n| Run | Target Modules | Trainable Params | Step 100 Acc | Step 200 Acc | Final Val Acc | Time |\n|-----|---------------|-----------------|-------------|-------------|---------------|------|\n| lang_only | q_proj, v_proj | 1,114,112 | 0.425 | 0.490 | 0.490 | 9.0 min |\n| lang_cross | q_proj, v_proj, k_proj, o_proj | 2,080,768 | 0.430 | 0.500 | 0.500 | 9.9 min |\n\n**Decision: lang_cross (q_proj, v_proj, k_proj, o_proj).** This is the strongest result \nacross all ablations: 50% accuracy at 200 steps, a full percentage point above lang_only. \nAdding k_proj and o_proj doubles the trainable parameters (1.1M → 2.1M) but still well \nunder the 5M budget. The extra adapters give the model more capacity to adjust its attention \npatterns, which makes sense for a multimodal task where the model needs to learn how to attend \nto visual features differently for science questions.\n\nBoth runs also show strong improvement from step 100 to 200 (6-7% jump), suggesting the model \nis still learning and the full training run should push accuracy higher.\n\n**Updated Decision for Axis 2**: Since there is room in the budget, it is worth testing rank 16 with more target modules.","metadata":{}},{"id":"8f68bab4-309f-4122-9eb1-ab31eb53b609","cell_type":"markdown","source":"### Combined Ablation: Pushing the Parameter Budget\n\n| Run | Strategy | Rank | Modules | Params | Step 100 | Step 200 | Time |\n|-----|----------|------|---------|--------|----------|----------|------|\n| axis3_lang_cross | generate | 8 | q/v/k/o | 2,080,768 | 0.430 | 0.500 | 9.9 min |\n| axis2x3_rank16_lang_cross | generate | 16 | q/v/k/o | 4,161,536 | 0.420 | 0.520 | 9.9 min |\n| axis1x2x3_rank16_lang_cross | loglikelihood | 16 | q/v/k/o | 4,161,536 | 0.435 | 0.520 | 10.9 min |\n\n**Takeaway:** More adapter capacity helps. Rank 16 with all four projection modules (4.2M params, \nstill under the 5M cap) outperforms rank 8 by 2%. Both scoring strategies land at exactly 52%, \nreconfirming that the two methods score similarly, so sticking with generate method for speed.\n\n","metadata":{}},{"id":"b80ed732-830f-4269-955e-57d69c963efc","cell_type":"markdown","source":"### Axis 4 Results: Learning Rate\n\n| Run | LR | Step 100 Acc | Step 200 Acc | Final Val Acc | Time |\n|-----|-----|-------------|-------------|---------------|------|\n| lr 1e-4 | 0.0001 | 0.435 | 0.460 | 0.460 | 10.0 min |\n| lr 2e-4 | 0.0002 | 0.440 | 0.505 | 0.505 | 10.0 min |\n| lr 5e-4 | 0.0005 | 0.485 | 0.450 | 0.450 | 10.0 min |\n\n**Decision: 2e-4.** The default learning rate wins. 1e-4 learns too slowly in 200 steps. \nIt might catch up with longer training but hasn't by step 200. 5e-4 is interesting: \nit jumps to 48.5% at step 100 (fastest early learning) but then *drops* to 45% by step 200. \nThis could be a sign of the learning rate being too high (fast initial progress then \ninstability or overfitting). 2e-4 shows steady improvement and lands at 50.5%.","metadata":{}},{"id":"8e00369e-ef31-4d0b-845a-6ec8b5d15240","cell_type":"markdown","source":"### Axis 5 Results: LoRA Alpha\n\n| Run | Alpha | Alpha/Rank Ratio | Step 100 Acc | Step 200 Acc | Final Val Acc | Time |\n|-----|-------|-----------------|-------------|-------------|---------------|------|\n| alpha 16 | 16 | 1.0 | 0.425 | 0.515 | 0.515 | 9.9 min |\n| alpha 32 | 32 | 2.0 | 0.460 | 0.490 | 0.490 | 10.0 min |\n\n**Decision: alpha 16 (ratio 1.0).** Alpha 32 shows the same pattern as the high learning rate: \nfaster start at step 100 but worse by step 200. This makes sense: increasing alpha scales up \nthe LoRA contribution, which has a similar effect to increasing the learning rate. Since 2e-4 \nis already the right LR, doubling the effective LoRA scale overshoots.\n\n**Final locked-in config for full training:**\n- Scoring strategy: generate\n- LoRA rank: 16\n- LoRA target modules: q_proj, v_proj, k_proj, o_proj\n- LoRA alpha: 16\n- LoRA dropout: 0.05\n- Learning rate: 2e-4\n- Context mode: full\n- Trainable params: 4,161,536 (83% of 5M budget)","metadata":{}},{"id":"04c8d068-e80b-48d4-8bcc-c40cff405514","cell_type":"markdown","source":"## NEW Ablation Axes & Notes","metadata":{}},{"id":"007a75cd-4397-47af-a53c-9b1be20a0ca0","cell_type":"markdown","source":"### Full Ablation Results\n\nAll runs: 300 steps, eval every 150, eval subset 100.\n\n| Run | Scoring | Rank | Modules | DoRA | Metadata | Answer Format | Params | Step 150 | Step 300 | Final Acc | Time (min) |\n|-----|---------|------|---------|------|----------|---------------|--------|----------|----------|-----------|------------|\n| a1_loglikelihood | loglikelihood | 8 | all7 | No | Yes | The correct answer is: | 4,784,128 | 0.620 | 0.550 | 0.550 | 11.9 |\n| a2_dora_r6 | generate | 6 | all7 | Yes | Yes | The correct answer is: | 3,892,224 | 0.600 | 0.600 | 0.600 | 23.1 |\n| a4_attn16_fmt_only | generate | 16 | attn4 | No | No | The correct answer is: | 4,161,536 | 0.610 | 0.600 | 0.600 | 9.3 |\n| a4_all7r8_bare | generate | 8 | all7 | No | No | Answer: | 4,784,128 | 0.600 | 0.600 | 0.600 | 10.6 |\n| a1_generate | generate | 8 | all7 | No | Yes | The correct answer is: | 4,784,128 | 0.590 | 0.610 | 0.610 | 11.6 |\n| a2_no_dora_r8 | generate | 8 | all7 | No | Yes | The correct answer is: | 4,784,128 | 0.570 | 0.610 | 0.610 | 11.5 |\n| a4_all7r8_meta_only | generate | 8 | all7 | No | Yes | Answer: | 4,784,128 | 0.610 | 0.610 | 0.610 | 10.7 |\n| a4_all7r8_fmt_only | generate | 8 | all7 | No | No | The correct answer is: | 4,784,128 | 0.590 | 0.610 | 0.610 | 10.6 |\n| a3_attn_only_dora | generate | 16 | attn4 | Yes | Yes | The correct answer is: | 4,271,104 | 0.620 | 0.650 | 0.650 | 14.6 |\n| a4_all7r6_dora_meta_fmt | generate | 6 | all7 | Yes | Yes | The correct answer is: | 3,892,224 | 0.580 | 0.670 | 0.670 | 20.5 |\n| a4_allhints_config | generate | 4 | all7 | Yes | Yes | The correct answer is: | 2,696,192 | 0.620 | 0.670 | 0.670 | 20.7 |\n| a3_attn_only | generate | 16 | attn4 | No | Yes | The correct answer is: | 4,161,536 | 0.570 | 0.680 | 0.680 | 10.1 |\n| a4_attn16_meta_only | generate | 16 | attn4 | No | Yes | Answer: | 4,161,536 | 0.570 | 0.680 | 0.680 | 9.3 |\n| a4_attn16_bare | generate | 16 | attn4 | No | No | Answer: | 4,161,536 | 0.610 | 0.690 | **0.690** | 9.7 |\n\n*Modules: attn4 = q/v/k/o_proj; all7 = q/v/k/o_proj + gate/up/down_proj*\n\n### Key Findings\n\n1. **Best config: attn4 r16, no DoRA, bare prompt (\"Answer:\", no metadata) = 69%**\n2. **Architecture:** attn4 r16 consistently outperforms all7 r8 across all prompt variations (~68-69% vs ~60-61%)\n3. **DoRA:** Hurts performance and doubles training time. No-DoRA beats DoRA in every matched comparison\n4. **Scoring:** Generate is stable; loglikelihood peaked at step 150 (62%) then collapsed to 55%\n5. **Prompt format:** \"Answer:\" outperforms \"The correct answer is:\" = maybe simpler is better\n6. **Metadata:** Neutral to slightly negative effect on attn4 r16 (69% without vs 68% with)","metadata":{}},{"id":"c9eb2dfc-15db-4b2f-938f-9cc522e1e224","cell_type":"markdown","source":"## 7. Ablation Comparisons & Summary","metadata":{}},{"id":"92a4e6c8-cff7-4fa6-8766-9544d0369e46","cell_type":"code","source":"# ── 7. Ablation Comparison: Plots + Summary Table ─────────────────────────────\nimport matplotlib.pyplot as plt\n\n# ── Plot 1: Final val accuracy bar chart ──────────────────────────────────────\nsorted_runs = sorted(ABLATION_RESULTS.items(), key=lambda x: x[1][\"final_val_accuracy\"])\nrun_names = [r[0] for r in sorted_runs]\naccs = [r[1][\"final_val_accuracy\"] for r in sorted_runs]\n\nfig, ax = plt.subplots(figsize=(10, max(4, len(run_names) * 0.5)))\nbars = ax.barh(run_names, accs, color=\"steelblue\", edgecolor=\"white\")\nax.set_xlabel(\"Final Val Accuracy\")\nax.set_title(\"Ablation Results: Final Validation Accuracy\", fontweight=\"bold\")\nax.set_xlim(0, max(accs) * 1.15)\n\nfor bar, acc in zip(bars, accs):\n    ax.text(bar.get_width() + 0.005, bar.get_y() + bar.get_height() / 2,\n            f\"{acc:.3f}\", va=\"center\", fontsize=9, fontweight=\"bold\")\n\nplt.tight_layout()\nplt.savefig(OUTPUT_DIR / \"ablation_accuracy.png\", dpi=150, bbox_inches=\"tight\")\nplt.show()\n\n# ── Plot 2: Accuracy trajectories overlaid ────────────────────────────────────\nfig, ax = plt.subplots(figsize=(12, 6))\nfor run_name, res in ABLATION_RESULTS.items():\n    if res[\"val_accuracies\"]:\n        steps, accs_traj = zip(*res[\"val_accuracies\"])\n        ax.plot(steps, accs_traj, marker=\"o\", markersize=5, linewidth=2, label=run_name)\n\nax.set_xlabel(\"Step\")\nax.set_ylabel(\"Val Accuracy\")\nax.set_title(\"Ablation: Accuracy Trajectories\", fontweight=\"bold\")\nax.legend(bbox_to_anchor=(1.05, 1), loc=\"upper left\", fontsize=7)\nax.set_ylim(0.4, max(accs) + 0.05)\nax.grid(True, alpha=0.3)\nplt.tight_layout()\nplt.savefig(OUTPUT_DIR / \"ablation_trajectories.png\", dpi=150, bbox_inches=\"tight\")\nplt.show()\n\n# ── Summary Table ─────────────────────────────────────────────────────────────\nsummary_rows = []\nfor run_name, res in ABLATION_RESULTS.items():\n    cfg = res[\"config\"]\n    modules = cfg[\"lora_target_modules\"]\n    if isinstance(modules, str):\n        modules = eval(modules)\n    has_mlp = any(m in modules for m in [\"gate_proj\", \"up_proj\", \"down_proj\"])\n    \n    summary_rows.append({\n        \"run\":              run_name,\n        \"scoring\":          cfg[\"scoring_strategy\"],\n        \"rank\":             cfg[\"lora_r\"],\n        \"modules\":          \"all7\" if has_mlp else \"attn4\",\n        \"DoRA\":             cfg.get(\"use_dora\", False),\n        \"metadata\":         cfg.get(\"include_metadata\", False),\n        \"answer_fmt\":       cfg.get(\"answer_format\", \"Answer:\"),\n        \"params\":           res[\"trainable_params\"],\n        \"step_150_acc\":     res[\"val_accuracies\"][0][1] if res[\"val_accuracies\"] else None,\n        \"final_val_acc\":    round(res[\"final_val_accuracy\"], 3),\n        \"time_min\":         round(res[\"total_time_min\"], 1),\n    })\n\nsummary_df = pd.DataFrame(summary_rows).sort_values(\n    \"final_val_acc\", ascending=False\n).reset_index(drop=True)\n\nprint(\"\\n── Ablation Summary (so