    include_metadata: if True, adds the subject metadata to the prompt\n    caption: if provided, adds a pre-generated image description to the prompt\n    \"\"\"\n    context_parts = []\n    lecture = row.get(\"lecture\", \"\")\n    hint    = row.get(\"hint\", \"\")\n\n    if context_mode == \"full\":\n        if pd.notna(lecture) and str(lecture).strip():\n            context_parts.append(str(lecture).strip())\n        if pd.notna(hint) and str(hint).strip():\n            context_parts.append(str(hint).strip())\n    elif context_mode == \"hint_only\":\n        if pd.notna(hint) and str(hint).strip():\n            context_parts.append(str(hint).strip())\n\n    context_str = \"\\n\".join(context_parts)\n    choices = row[\"choices\"]\n    choices_str = \"\\n\".join(\n        f\"  {CHOICE_LETTERS[i]}. {c}\" for i, c in enumerate(choices)\n    )\n\n    prompt = \"<image>\\n\"\n\n    if include_metadata:\n        subject = row.get(\"subject\", \"\")\n        grade   = row.get(\"grade\", \"\")\n        if pd.notna(subject) and str(subject).strip():\n            prompt += f\"Subject: {str(subject).strip()}\"\n            if pd.notna(grade) and str(grade).strip():\n                prompt += f\" | Grade: {str(grade).strip()}\"\n            prompt += \"\\n\\n\"\n\n    if caption:\n        prompt += f\"Image description: {caption}\\n\\n\"\n\n    if prompt_format == \"context_first\":\n        if context_str:\n            prompt += f\"Context:\\n{context_str}\\n\\n\"\n        prompt += f\"Question: {row['question']}\\n\"\n        prompt += f\"Choices:\\n{choices_str}\\n\"\n    elif prompt_format == \"question_first\":\n        prompt += f\"Question: {row['question']}\\n\"\n        prompt += f\"Choices:\\n{choices_str}\\n\"\n        if context_str:\n            prompt += f\"\\nContext:\\n{context_str}\\n\"\n\n    prompt += answer_format\n\n    if include_answer:\n        answer_idx = int(row[\"answer\"])\n        prompt += f\" {CHOICE_LETTERS[answer_idx]}\"\n\n    return promp